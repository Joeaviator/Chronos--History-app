{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores basic user information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "User's display name." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "description": "URL to user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "When the user last logged in." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the application." },
        "appsUsed": { "type": "array", "items": { "type": "string" }, "description": "List of apps the user has used in the ecosystem." }
      },
      "required": ["uid", "email", "createdAt", "role"]
    },
    "UserProgress": {
      "title": "User Progress",
      "description": "Stores user's historical exploration progress and analytics metrics for the StarVortex Command Deck.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Reference to the user." },
        "unlockedEras": { "type": "array", "items": { "type": "string" }, "description": "List of era IDs the user has explored." },
        "completedMissions": { "type": "array", "items": { "type": "string" }, "description": "List of mission IDs completed." },
        "collectedArtifacts": { "type": "array", "items": { "type": "string" }, "description": "List of artifact IDs collected." },
        "totalPoints": { "type": "number", "description": "Total points earned." },
        "forecasts_generated": { "type": "number", "description": "Number of AI interactions (Talk Mode)." },
        "accuracy_score": { "type": "number", "description": "Average performance score in missions (0-100)." },
        "timeline_events_tracked": { "type": "number", "description": "Number of unique history events explored." },
        "active_simulations": { "type": "number", "description": "Total number of missions attempted." }
      },
      "required": ["uid", "unlockedEras", "completedMissions", "collectedArtifacts", "totalPoints", "forecasts_generated", "accuracy_score", "timeline_events_tracked", "active_simulations"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/users/{userId}/progress/data": {
      "schema": "UserProgress",
      "description": "Detailed progress data for a specific user."
    }
  }
}
